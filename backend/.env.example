# xAI / Grok configuration
XAI_API_KEY=your-xai-api-key-here

# Text model for Research, Insurance, Provider, Synthesis, Charter Check
XAI_TEXT_MODEL=grok-3

# Grok Voice model for Voice Executor agent
XAI_VOICE_MODEL=grok-voice-latest

# Optional overrides
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_VOICE_URL=wss://api.x.ai/v1/realtime?model=grok-voice-latest
# XAI_REQUEST_TIMEOUT=120
# XAI_VOICE_TURN_TIMEOUT=45
# APO_VOICE_MAX_TURNS=5

# Without XAI_API_KEY, agents fall back to stub responses for local dev.

# Optional Twilio outbound (Path C — real phone call demo)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# TWILIO_DEMO_TO_NUMBER=+1XXXXXXXXXX
# PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app
